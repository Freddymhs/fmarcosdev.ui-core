{
  "name": "@fmarcosdev/ui-core",
  "version": "0.1.1",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --target es2020",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch --target es2020",
    "lint": "eslint \"src/**/*.{ts,tsx}\""
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "tsup": "^8.3.0",
    "typescript": "^5.7.2"
  }
}
